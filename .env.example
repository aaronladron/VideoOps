# Configuration de l'Application

# Port du serveur local (http-server)
HTTP_SERVER_PORT=8080

# Port Docker
DOCKER_PORT=8080

# Niveau d'audit npm (high, moderate, low)
NPM_AUDIT_LEVEL=moderate

# Node.js version
NODE_VERSION=20

# Environnement (development, production)
NODE_ENV=production

# Configuration CORS
CORS_ENABLED=true

# Verbosité des logs
DEBUG=false
